# Copy this file to .env and fill in real values. Never commit .env itself.

# --- AWS ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_PROFILE=qufoods

# Raw bucket -- read-only, already running, owned outside the team
QUFOODS_RAW_BUCKET=qufoods-raw

# Processed bucket -- created by the team in PLANNING phase
QUFOODS_PROCESSED_BUCKET=

# --- Neon PostgreSQL (gold layer) ---
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Amazon Bedrock (optional narrative layer, non-blocking) ---
BEDROCK_MODEL_ID=
BEDROCK_REGION=us-east-1

# --- Pipeline behavior ---
# Exploration uses a wide lookback for profiling; Lambda in production uses 5.
LOOKBACK_MINUTES=1440
TYPO_MATCH_CUTOFF=75
